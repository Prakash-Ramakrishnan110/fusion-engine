{
  "rewrites": [
    {
      "source": "/((?!assets/.*|dist/.*).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://fusion-engine.vercel.app/$1",
      "has": [
        {
          "type": "host",
          "value": "www.fusion-engine.vercel.app"
        }
      ]
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite"
}